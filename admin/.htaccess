# ── Securitate director admin ────────────────────────────────

# Interzice listarea directorului
Options -Indexes

# Security headers (dublat față de PHP pentru static files)
<IfModule mod_headers.c>
    Header always set X-Frame-Options "DENY"
    Header always set X-Content-Type-Options "nosniff"
    Header always set Referrer-Policy "no-referrer"
    Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"
</IfModule>

# Blochează accesul direct la auth.php (se include, nu se accesează direct)
<Files "auth.php">
    Require all denied
</Files>

# Blochează accesul direct la fișiere interne
<FilesMatch "^(auth|install|partials)\.php$">
    Require all denied
</FilesMatch>
